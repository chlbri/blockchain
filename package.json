{
  "name": "@bemedev/blockchain",
  "version": "0.0.1",
  "description": "Blockchain to sell",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/blockchain.git"
  },
  "license": "MIT",
  "type": "module",
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "blockchain",
    "smart contracts",
    "web3",
    "sales"
  ],
  "files": [
    "lib",
    "public"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "ci": "pnpm run config:off && pnpm run lint && pnpm run test && pnpm run prettier && pnpm run p-q",
    "ci:admin": "pnpm run rm && pnpm run upgrade && pnpm run ci",
    "clean": "pnpm run rm && pnpm run config",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "eslint": "eslint \"{src/**/*,App}.{ts,tsx}\"",
    "lint": "pnpm run prettier && pnpm run eslint --fix",
    "lint:watch": "onchange --await-write-finish 5500 \"**/*\" -- pnpm run lint",
    "prepublishOnly": "",
    "prepare": "husky",
    "pretest": "pnpm run build",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "p-q": "pretty-quick",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rimraf": "pnpx rimraf -rf",
    "rm": "pnpm run rimraf -- node_modules pnpm-lock.yaml",
    "rm:lib": "pnpm run rimraf -- lib",
    "rollup": "rollup -c",
    "size": "size-limit",
    "test": "pnpm run test:coverage --no-coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:coverage": "vitest run",
    "typings": "app-typings generate",
    "typings:watch": "pnpm run typings --watch",
    "test:watch": "vitest",
    "dev": "vite dev",
    "build": "vite build",
    "upgrade": "pnpm up --latest && pnpm add @tanstack/solid-router@1.131.49 @tanstack/solid-router-devtools@1.131.49 @tanstack/solid-start@1.131.49"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/app-cli": "^0.1.7",
    "@bemedev/fsf": "^0.8.0",
    "@bemedev/rollup-config": "^0.2.1",
    "@bemedev/vitest-alias": "^0.0.3",
    "@bemedev/vitest-exclude": "^0.1.1",
    "@bemedev/vitest-extended": "^1.5.3",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@size-limit/file": "^11.2.0",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.36.0",
    "glob": "^11.0.3",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "rollup": "^4.52.2",
    "size-limit": "^11.2.0",
    "tslib": "^2.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite-plugin-solid": "^2.11.8",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild"
    ]
  },
  "dependencies": {
    "@bemedev/app-solid": "^0.2.4",
    "@bemedev/app-ts": "^1.0.3",
    "@bemedev/i18n": "^0.3.0",
    "@bemedev/sleep": "0.1.2",
    "@kobalte/core": "0.13.11",
    "@tailwindcss/vite": "4.1.13",
    "@tanstack/solid-router": "1.131.49",
    "@tanstack/solid-router-devtools": "1.131.49",
    "@tanstack/solid-start": "1.131.49",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "color": "5.0.2",
    "fast-equals": "^5.3.0",
    "localstorage-slim": "^2.7.1",
    "nanoid": "^5.1.6",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.9",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "ts-deepmerge": "^7.0.3",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.1.7"
  }
}
